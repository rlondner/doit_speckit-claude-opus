{
  "openapi": "3.0.3",
  "info": {
    "title": "Do It — Goal Tracker API",
    "description": "API for managing goals in the Do It goal tracking application.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/goals": {
      "get": {
        "summary": "List all goals",
        "description": "Returns all goals, both active and completed. Active goals are sorted by end_date ascending, completed goals by completed_at descending.",
        "operationId": "listGoals",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Filter by goal status",
            "schema": {
              "type": "string",
              "enum": ["active", "completed"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of goals",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "goals": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Goal"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new goal",
        "description": "Creates a new active goal. The end date must not be in the past.",
        "operationId": "createGoal",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGoalInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Goal created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Goal"
                }
              }
            }
          },
          "400": {
            "description": "Validation error (empty title or past end date)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/goals/{id}": {
      "patch": {
        "summary": "Update a goal",
        "description": "Update a goal's status. Setting status to 'completed' sets completed_at to now. Setting status to 'active' clears completed_at.",
        "operationId": "updateGoal",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Goal UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateGoalInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Goal updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Goal"
                }
              }
            }
          },
          "404": {
            "description": "Goal not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a goal",
        "description": "Permanently deletes a goal from either active or completed state.",
        "operationId": "deleteGoal",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Goal UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Goal deleted successfully"
          },
          "404": {
            "description": "Goal not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Goal": {
        "type": "object",
        "required": ["id", "title", "endDate", "status", "createdAt", "completedAt"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique goal identifier"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Goal title"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "Target completion date (YYYY-MM-DD)"
          },
          "status": {
            "type": "string",
            "enum": ["active", "completed"],
            "description": "Current goal state"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the goal was created"
          },
          "completedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "When the goal was marked complete (null if active)"
          }
        }
      },
      "CreateGoalInput": {
        "type": "object",
        "required": ["title", "endDate"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Goal title"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "Target completion date (YYYY-MM-DD). Must not be in the past."
          }
        }
      },
      "UpdateGoalInput": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["active", "completed"],
            "description": "New goal status"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}
